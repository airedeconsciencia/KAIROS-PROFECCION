  state.lastDiagnostic = newAsc.diagnostic;
  state.user.birthUtcOffset = newOff;
  state.user.asc = newAsc.sign;
  state.user.ascDeg = newAsc.deg;
  state.user.ascMin = newAsc.min;
  state.user.engineVersion = 48.3;
