      // KAIROS v650v5.0 — BASE ESTABLE CONGELADA
      const V_STABLE = '650.5.0';
      if (localStorage.getItem('current_v') !== V_STABLE) {
        console.log("✅ KAIROS v650v5.0: Base Estable Congelada");
        console.log("📍 KAIROS: Purging legacy cache and refreshing to v" + V_STABLE);
        localStorage.clear();
        localStorage.setItem('current_v', V_STABLE);
        if ('serviceWorker' in navigator) {
          navigator.serviceWorker.getRegistrations().then(function(regs) {
            for(let r of regs) { r.unregister(); }
          });
        }
        if ('caches' in window) {
          caches.keys().then(function(ns) {
            for (let n of ns) caches.delete(n);
          });
        }
        // We delay reload slightly to allow storage writes to commit
        setTimeout(() => { location.reload(true); }, 300);
      }

      // GLOBAL ERROR HANDLER TO PREVENT SILENT WHITE SCREEN
      window.onerror = function(msg, url, lineNo, columnNo, error) {
        console.error("🔥 FATAL ERROR:", msg, "at", url, ":", lineNo);
        const errEl = document.getElementById('bootstrap-error');
        const errTxt = document.getElementById('bootstrap-errorText');
        if (errEl && errTxt) {
          errEl.classList.remove('hidden');
          errTxt.innerText = "Error Crítico: " + msg;
          const status = document.getElementById('shell-bootstrap-message');
          if (status) status.classList.remove('hidden');
        }
        return false;
      };
    </script>
